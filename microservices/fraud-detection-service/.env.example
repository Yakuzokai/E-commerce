PORT=3013
NODE_ENV=production

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/fraud_detection

REDIS_HOST=redis
REDIS_PORT=6379

KAFKA_BROKERS=kafka:9092

# Fraud Detection Config
FRAUD_THRESHOLD=0.7
ANOMALY_THRESHOLD=2.5
MIN_TRANSACTIONS_FOR_LEARNING=100
RISK_SCORE_WEIGHTS='{"velocity":0.3,"amount":0.25,"geolocation":0.2,"device":0.15,"history":0.1}'