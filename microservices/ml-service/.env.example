PORT=3012
NODE_ENV=production

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ml_service

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=kafka:9092

# ML Model Config
MODEL_UPDATE_INTERVAL=0 6 * * *
TRAINING_BATCH_SIZE=1000
EMBEDDING_DIM=128
COLLABORATIVE_FILTER_THRESHOLD=0.3